# OpenAI API
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=           # optional, defaults to https://api.openai.com/v1
OPENAI_MODEL=gpt-4o          # vision model for OCR (must support image input)
OPENAI_TEXT_MODEL=gpt-4o-mini # text model for analysis + video script
# OPENAI_IMAGE_MODEL=dall-e-3  # image model for totem generation (defaults to dall-e-3)

# BytePlus Ark (used for video generation via generate.py)
ARK_API_KEY=xxx

# ffmpeg / ffprobe — defaults to system PATH if not set
# FFMPEG_BIN=/usr/local/bin/ffmpeg
# FFPROBE_BIN=/usr/local/bin/ffprobe
# FFMPEG_ROOT=/path/to/ffmpeg/source  # only needed for custom-built ffmpeg with DYLD libs
